# ==============================================================================
# PLANTILLA .env.restic — Copiar a .env.restic y rellenar (NO subir al repo)
# ==============================================================================

# Contraseña maestra de cifrado Restic (usa una larga y guárdala en lugar seguro)
export RESTIC_PASSWORD="TU_CONTRASEÑA_MAESTRA_SUPER_SEGURA"

# Cloudflare R2 — credenciales S3 compatibles
export AWS_ACCESS_KEY_ID="TU_CLOUDFLARE_R2_ACCESS_KEY_ID"
export AWS_SECRET_ACCESS_KEY="TU_CLOUDFLARE_R2_SECRET_ACCESS_KEY"

# Repositorio Restic en R2
# Formato: s3:https://<account_id>.r2.cloudflarestorage.com/<nombre-bucket>
export RESTIC_REPOSITORY="s3:https://TU_ACCOUNT_ID.r2.cloudflarestorage.com/yggdrasil-backup-madre"

{
  "dashboard": {
    "title": "Yggdrasil Overview",
    "uid": "yggdrasil-main",
    "panels": [
      {
        "id": 1,
        "type": "graph",
        "title": "Tool Executions Total",
        "targets": [
          {"expr": "rate(ygg_tool_executions_total[5m])", "legendFormat": "{{tool}} {{status}}"}
        ],
        "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
      },
      {
        "id": 2,
        "type": "graph",
        "title": "Tool Latency (seconds)",
        "targets": [
          {"expr": "ygg_tool_latency_seconds", "legendFormat": "{{tool}}"}
        ],
        "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "30s"
  },
  "overwrite": true
}

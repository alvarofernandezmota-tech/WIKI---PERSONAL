# =============================================================================
# .env.plantilla — Copiar como .env y rellenar valores
# cp setup/servidor/.env.plantilla setup/servidor/.env
# NUNCA subir .env al repo (está en .gitignore)
# =============================================================================

# --- FASE 1: Stack IA Core ---
OLLAMA_HOST=0.0.0.0
OLLAMA_NUM_PARALLEL=2
OLLAMA_MAX_LOADED_MODELS=2
OPEN_WEBUI_PORT=3000
QDRANT_PORT=6333

# --- FASE 1b: Seguridad ---
SSH_PORT=22
UFW_ENABLED=true

# --- FASE 2: Batcueva monitoring ---
PORTAINER_PORT=9000
UPTIME_KUMA_PORT=3001
SPIDERFOOT_PORT=5001

# --- FASE 3: Servicios ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_ADMIN_PORT=81
VAULTWARDEN_PORT=8082
N8N_PORT=5678
CODE_SERVER_PORT=8443
GITEA_PORT=3002
PAPERLESS_PORT=8010

# --- FASE 4: LiteLLM + IA APIs ---
LITELLM_PORT=4000
LITELLM_MASTER_KEY=sk-batcueva-CAMBIAR-ESTO
LITELLM_DB_PASSWORD=CAMBIAR-ESTO

# APIs externas (dejar vacío si no tienes)
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENAI_API_KEY=
SHODAN_API_KEY=
PERPLEXITY_API_KEY=

# --- Base de datos (Fase 4) ---
POSTGRES_DB=litellm
POSTGRES_USER=litellm
POSTGRES_PASSWORD=CAMBIAR-ESTO
REDIS_PASSWORD=CAMBIAR-ESTO

# --- Telegram (thdora) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Tailscale ---
TAILSCALE_AUTHKEY=

{
  "name": "ecosystem-snapshot",
  "description": "Recoge estado del ecosistema cada 15 minutos y alimenta el health-agent",
  "version": "1.0.0",
  "sesion_creacion": "2026-07-03",
  "nodes": [
    {
      "id": "trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "name": "Cron cada 15 min",
      "parameters": {
        "rule": { "interval": [{ "field": "minutes", "minutesInterval": 15 }] }
      }
    },
    {
      "id": "docker_state",
      "type": "n8n-nodes-base.executeCommand",
      "name": "1. Estado Docker",
      "parameters": {
        "command": "docker ps --format '{\"name\":\"{{.Names}}\",\"status\":\"{{.Status}}\",\"state\":\"{{.State}}\"}' | jq -s '.'"
      }
    },
    {
      "id": "ping_services",
      "type": "n8n-nodes-base.httpRequest",
      "name": "2. Ping servicios",
      "notes": "Replicar para cada servicio: open-webui:3000, n8n:5678, gitea:3000, thdora:8000",
      "parameters": {
        "url": "http://madre:8000/health",
        "method": "GET",
        "timeout": 5000,
        "continueOnFail": true
      }
    },
    {
      "id": "github_workflows",
      "type": "n8n-nodes-base.httpRequest",
      "name": "3. Estado GitHub Actions",
      "parameters": {
        "url": "https://api.github.com/repos/alvarofernandezmota-tech/yggdrasil-dew/actions/runs?per_page=5",
        "method": "GET",
        "headers": {
          "Authorization": "Bearer {{ $env.GITHUB_TOKEN }}",
          "Accept": "application/vnd.github+json"
        }
      }
    },
    {
      "id": "build_snapshot",
      "type": "n8n-nodes-base.code",
      "name": "4. Construir EcosystemSnapshot",
      "parameters": {
        "jsCode": "// Construye el JSON que espera health-agent-core\nconst containers = JSON.parse($node['1. Estado Docker'].json.stdout || '[]');\nconst services = [\n  { name: 'thdora-personal', reachable: $node['2. Ping servicios'].json.statusCode === 200, latency_ms: $node['2. Ping servicios'].json.responseTime || null }\n];\nconst runs = $node['3. Estado GitHub Actions'].json.workflow_runs || [];\nconst workflows = runs.slice(0,3).map(r => ({\n  name: r.name,\n  last_run: r.updated_at,\n  status: r.conclusion || r.status\n}));\n\nreturn [{\n  json: {\n    timestamp: new Date().toISOString(),\n    containers: containers.map(c => ({\n      name: c.name,\n      status: c.state,\n      last_restart: null\n    })),\n    services,\n    workflows,\n    notes: null\n  }\n}];"
      }
    },
    {
      "id": "call_health_agent",
      "type": "n8n-nodes-base.httpRequest",
      "name": "5. Llamar health-agent",
      "parameters": {
        "url": "http://madre:8000/health/evaluate",
        "method": "POST",
        "body": "={{ JSON.stringify($json) }}",
        "headers": { "Content-Type": "application/json" },
        "timeout": 60000
      }
    },
    {
      "id": "check_status",
      "type": "n8n-nodes-base.if",
      "name": "6. ¿Necesita alerta?",
      "parameters": {
        "conditions": {
          "string": [{
            "value1": "={{ $json.global_status }}",
            "operation": "notEqual",
            "value2": "OK"
          }]
        }
      }
    },
    {
      "id": "telegram_alert",
      "type": "n8n-nodes-base.telegram",
      "name": "7. Alerta Telegram",
      "notes": "Solo si global_status != OK",
      "parameters": {
        "chatId": "{{ $env.TELEGRAM_CHAT_ID }}",
        "text": "🔴 *Ecosistema {{ $json.global_status }}*\n\n{{ $json.analysis }}\n\nAcciones propuestas:\n{{ $json.actions.map(a => `- [${a.severity}] ${a.description}`).join('\\n') }}",
        "parseMode": "Markdown"
      }
    }
  ],
  "connections": {
    "trigger": { "main": [[{ "node": "docker_state" }]] },
    "docker_state": { "main": [[{ "node": "ping_services" }]] },
    "ping_services": { "main": [[{ "node": "github_workflows" }]] },
    "github_workflows": { "main": [[{ "node": "build_snapshot" }]] },
    "build_snapshot": { "main": [[{ "node": "call_health_agent" }]] },
    "call_health_agent": { "main": [[{ "node": "check_status" }]] },
    "check_status": { "main": [[{ "node": "telegram_alert" }], []] }
  },
  "settings": {
    "errorWorkflow": "guardian-error-handler",
    "saveExecutionProgress": true,
    "saveManualExecutions": true
  }
}
